{
  "name": "uat-test",
  "version": "0.0.0",
  "description": "Scratch consumer for @mahirick/users-and-teams. Talks to the package via a file: dep, not the Vite alias the in-repo demo uses.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:backend": "tsx --env-file=backend/.env backend/server.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "reset": "rm -f backend/test.db backend/test.db-* && echo 'db reset'",
    "update": "(cd .. && npm run build) && npm install --no-audit --no-fund"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^11.0.0",
    "@mahirick/users-and-teams": "file:..",
    "better-sqlite3": "^11.5.0",
    "fastify": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
