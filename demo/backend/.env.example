# Demo backend env. Copy to .env to override.
PORT=3000
HOST=127.0.0.1
DB_PATH=./demo/backend/demo.db

# Where the user-facing app lives. Magic-link emails point here.
SITE_URL=http://localhost:5173
SITE_NAME=Users-and-Teams Demo

# Email transport: "console" (default, logs to stdout) or "resend".
EMAIL_TRANSPORT=console

# Resend (only required if EMAIL_TRANSPORT=resend)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com

# Comma-separated emails that auto-receive role=admin on signup.
ADMIN_EMAILS=admin@example.com

# Cookie name (must be the same the frontend reads, but cookies are HttpOnly so the frontend never reads it directly anyway).
COOKIE_NAME=uat_demo_session
